# =============================================================================
# 环境变量模板
# -----------------------------------------------------------------------------
# 使用方式：
#   cp .env.example apps/backend/.env   # 后端本地开发
#   按需覆盖下列敏感字段（尤其是 JWT_* 与 OPENAI_API_KEY）
#
# 分环境策略（单一模板 + 环境覆盖，不维护多份 .env 文件）：
#   - development  本地开发：直接使用本文件，connect 本机 postgres/redis
#   - test         CI/单测：NODE_ENV=test，DATABASE_URL/REDIS_URL 指向 CI 容器
#                  JWT_* 允许使用任意 ≥32 位的测试 secret；测试脚本会在运行时
#                  设置默认值（见 apps/backend/tests/*.test.mjs 顶部）
#   - production   线上：所有敏感字段由部署平台 Secret 注入（不入库、不进镜像）
#                  docker-compose 已在 environment: 中覆盖容器内取值
#
# 优先级：部署平台 secrets > docker-compose environment > .env 文件 > 默认值
# =============================================================================

# ---- Backend ----
NODE_ENV=development
PORT=3000

# 数据库/缓存：容器内使用 service 名（postgres/redis），本机开发用 localhost
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/video_prompt
REDIS_URL=redis://localhost:6379

# 上传临时目录：生产建议挂载独立卷，避免容器重启丢文件
UPLOAD_DIR=/tmp/uploads
ASSET_CDN_BASE_URL=

# 前端域名，生产切换为线上域名（如 https://vtp.example.com）
CORS_ORIGIN=http://localhost:5173

# JWT：生产必须替换为 ≥32 位强随机值，建议通过密钥管理服务下发
JWT_ACCESS_SECRET=replace-with-32-char-access-secret
JWT_REFRESH_SECRET=replace-with-32-char-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI 分析：development/test 默认 mock（不消耗额度）；production 切智谱
ANALYSIS_PROVIDER=mock
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_API_KEY=
OPENAI_MODEL=glm-4.1v-thinking-flashx
OPENAI_API_STYLE=chat

# 队列/采样：高并发生产可调大 concurrency，注意 ffmpeg 子进程内存占用
ANALYSIS_QUEUE_CONCURRENCY=1
UPLOAD_URL_QUEUE_CONCURRENCY=1
ANALYSIS_MAX_FRAMES=50
ANALYSIS_CACHE_TTL_SECONDS=86400

# OAuth（第三方登录）
OAUTH_FRONTEND_CALLBACK_URL=http://localhost:5173/oauth/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback
OAUTH_WECHAT_APP_ID=
OAUTH_WECHAT_APP_SECRET=
OAUTH_WECHAT_REDIRECT_URI=http://localhost:3000/api/auth/oauth/wechat/callback
OAUTH_WECHAT_SCOPE=snsapi_userinfo

# 安全与合规
SECURITY_ENABLE_HTTPS_REDIRECT=false
SECURITY_HTTPS_PORT=443
DATA_DELETION_GRACE_DAYS=7

# ---- Frontend ----
# 开发走 vite proxy 即可留空；生产填后端公网地址
VITE_API_BASE_URL=http://localhost:3000
