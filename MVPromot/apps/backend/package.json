{
  "name": "@vtp/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "types": "tsc --noEmit",
    "test": "npm run build && node --test --test-isolation=none tests/auth.service.test.mjs tests/frame-extractor.service.test.mjs tests/upload-url-task.store.test.mjs tests/analysis-prompt.service.test.mjs",
    "test:coverage": "npm run build && node --test --test-isolation=none --experimental-test-coverage tests/auth.service.test.mjs tests/frame-extractor.service.test.mjs tests/upload-url-task.store.test.mjs tests/analysis-prompt.service.test.mjs",
    "test:e2e:upload-url": "node tests/upload-url.e2e.mjs",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:resolve:init": "prisma migrate resolve --applied 20260413133000_init"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.2.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.3.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@prisma/client": "^6.0.1",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.34.10",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "ytdl-core": "^4.11.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prisma": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
