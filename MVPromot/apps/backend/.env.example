NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/video_prompt
REDIS_URL=redis://localhost:6379
UPLOAD_DIR=/tmp/uploads
CORS_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=replace-with-32-char-access-secret
JWT_REFRESH_SECRET=replace-with-32-char-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# 本地冒烟可用 mock；第一关验收请切到 openai 并提供真实 Key
ANALYSIS_PROVIDER=mock
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANALYSIS_QUEUE_CONCURRENCY=1
ANALYSIS_MAX_FRAMES=50
